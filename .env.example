APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=7000
APP_BASE_URL=http://localhost:7000
APP_TIMEZONE=UTC
APP_LOG_LEVEL=info

DATABASE_DRIVER=postgres
DATABASE_URL=

APP_ENCRYPTION_KEY=
APP_SESSION_SECRET=

APP_BOOTSTRAP_EMAIL=
APP_BOOTSTRAP_PASSWORD=

SECURE_COOKIES=false
TRUSTED_PROXIES=
ALLOWED_ORIGINS=

WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=2s
TASK_DEFAULT_TIMEOUT=10m
TASK_MAX_RETRIES=3

CHAT_DEFAULT_TIMEOUT=5m
CHAT_MAX_TOOL_ITERATIONS=8
CHAT_CONTEXT_THRESHOLD=60000
CHAT_RECENT_MESSAGE_LIMIT=30

SESSION_TTL=720h
TASK_RUN_RETENTION=720h
AUDIT_LOG_RETENTION=2160h

DATA_DIR=/data
MIGRATIONS_DIR=migrations
WEB_DIST_DIR=web/dist
